APP_NAME="Ninja Sage Clone Server"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://ninjasage.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ninjasage
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_VALIDATE_BYPASS=false # Set true if want to bypass session validation

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
APP_TIMEZONE=Asia/Kuala_Lumpur


# PVP Socket.IO server URL — sent to Flash clients via SystemLogin.checkVersion
# Set to the public URL of the pvp-server Node.js process
PVP_SOCKET_URL=http://127.0.0.1:3000/pvp

# Chat WebSocket server URL — sent to Flash clients via SystemLogin.checkVersion
# Set to the public URL of the chat-server Node.js process (no trailing slash)
CHAT_SOCKET_URL=http://127.0.0.1:3002

# Internal base URL of the chat-server (used by the admin panel to call /admin/announce)
# On the same machine this is always 127.0.0.1; change only if chat-server runs elsewhere
CHAT_INTERNAL_URL=http://127.0.0.1:3002

# Shared secret for the chat-server admin API — must match CHAT_ADMIN_SECRET in chat-server/.env
CHAT_ADMIN_SECRET=change-me-to-a-random-secret

# Absolute path to the Client/skills directory containing skill SWF files.
# The Flash client loads these as https://ninjasage.test/skills/skill_XXXX.swf.
# Leave blank to use the default (../../../Client/skills relative to the Laravel project root).
# On Windows Laragon you will likely need to set this explicitly, e.g.:
# SKILL_SWF_PATH=C:/path/to/repo/Client/skills
SKILL_SWF_PATH=

# Fallback SWF filename served when a custom skill has no dedicated SWF file.
# Defaults to skill_01.swf. Change to any existing SWF in the SKILL_SWF_PATH folder.
SKILL_DEFAULT_SWF=skill_01.swf
